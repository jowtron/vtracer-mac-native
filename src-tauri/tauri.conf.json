{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vTracer",
  "version": "0.1.0",
  "identifier": "com.vtracer.app",
  "build": {
    "beforeDevCommand": null,
    "beforeBuildCommand": null,
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "vTracer Clone",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "capabilities": [
        "main-capability"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
